{
	"$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
	"Name": "Mac Jump",
	"Version": "1.1.0.0",
	"Author": "John Knox",
	"Description": "Mac automation for Stream Deck: jump to Safari tabs (multi-account Gmail/Calendar, custom sites, private windows), scroll the frontmost window with a dial, and open/switch apps by window title.",
	"Category": "Mac Jump",
	"CategoryIcon": "imgs/plugin/category-icon",
	"Icon": "imgs/plugin/marketplace",
	"SDKVersion": 2,
	"CodePath": "bin/plugin.js",
	"Nodejs": {
		"Version": "20",
		"Debug": "enabled"
	},
	"Software": {
		"MinimumVersion": "6.5"
	},
	"OS": [
		{
			"Platform": "mac",
			"MinimumVersion": "12"
		}
	],
	"UUID": "com.johnknox.safarijump",
	"Actions": [
		{
			"Name": "Jump to Tab",
			"UUID": "com.johnknox.safarijump.jump",
			"Icon": "imgs/actions/jump/icon",
			"Tooltip": "Jump to an open Safari tab, or open it if missing.",
			"PropertyInspectorPath": "ui/jump-to-tab.html",
			"Controllers": ["Keypad"],
			"States": [
				{
					"Image": "imgs/actions/jump/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Scroll Window",
			"UUID": "com.johnknox.safarijump.scroll",
			"Icon": "imgs/actions/scroll/icon",
			"Tooltip": "Dial: scroll the frontmost window. Press to jump to top or toggle fast/slow.",
			"PropertyInspectorPath": "ui/scroll-window.html",
			"Controllers": ["Encoder"],
			"Encoder": {
				"layout": "$B1",
				"TriggerDescription": {
					"Rotate": "Scroll up / down",
					"Push": "Jump to top / toggle speed"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/scroll/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Open / Switch App",
			"UUID": "com.johnknox.safarijump.switchapp",
			"Icon": "imgs/actions/switchapp/icon",
			"Tooltip": "Open or switch to an app, optionally focusing a window by title pattern.",
			"PropertyInspectorPath": "ui/switch-app.html",
			"Controllers": ["Keypad"],
			"States": [
				{
					"Image": "imgs/actions/switchapp/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Focus tmux Window",
			"UUID": "com.johnknox.safarijump.tmux",
			"Icon": "imgs/actions/tmux/icon",
			"Tooltip": "Raise the iTerm2 window for a tmux window, and optionally switch to it.",
			"PropertyInspectorPath": "ui/focus-tmux.html",
			"Controllers": ["Keypad"],
			"States": [
				{
					"Image": "imgs/actions/tmux/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Switch tmux Pane",
			"UUID": "com.johnknox.safarijump.tmuxpane",
			"Icon": "imgs/actions/tmuxpane/icon",
			"Tooltip": "Dial: rotate to switch tmux panes; push to exit copy-mode (back to the prompt).",
			"Controllers": ["Encoder"],
			"Encoder": {
				"layout": "$B1",
				"TriggerDescription": {
					"Rotate": "Previous / next pane",
					"Push": "Exit copy-mode (scroll to bottom)"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/tmuxpane/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Cycle tmux Window",
			"UUID": "com.johnknox.safarijump.tmuxwindial",
			"Icon": "imgs/actions/tmuxwindial/icon",
			"Tooltip": "Dial: rotate to cycle tmux windows; push for last window. Shows the current window on the touchscreen.",
			"Controllers": ["Encoder"],
			"Encoder": {
				"layout": "layouts/tmux-window.json",
				"TriggerDescription": {
					"Rotate": "Previous / next window",
					"Push": "Last window"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/tmuxwindial/key",
					"TitleAlignment": "bottom"
				}
			]
		}
	]
}

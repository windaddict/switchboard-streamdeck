{
	"$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
	"Name": "Switchboard",
	"Version": "1.2.0.0",
	"Author": "Moving Average Labs",
	"Description": "Switchboard — an operator's control surface for macOS: jump to Safari tabs (multi-account Gmail/Calendar, custom, private), scroll and switch windows and apps, drive tmux windows/panes, cycle BBEdit documents, and open the right file from a folder.",
	"Category": "Switchboard",
	"CategoryIcon": "imgs/plugin/category-icon",
	"Icon": "imgs/plugin/marketplace",
	"SDKVersion": 2,
	"CodePath": "bin/plugin.js",
	"Nodejs": {
		"Version": "20",
		"Debug": "enabled"
	},
	"Software": {
		"MinimumVersion": "6.5"
	},
	"OS": [
		{
			"Platform": "mac",
			"MinimumVersion": "12"
		}
	],
	"UUID": "com.movingavg.switchboard",
	"Actions": [
		{
			"Name": "Safari Tab Jump",
			"UUID": "com.movingavg.switchboard.jump",
			"Icon": "imgs/actions/jump/icon",
			"Tooltip": "Jump to an open Safari tab, or open it if missing. Hold to capture the current tab.",
			"PropertyInspectorPath": "ui/jump-to-tab.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/jump/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Scroll Window",
			"UUID": "com.movingavg.switchboard.scroll",
			"Icon": "imgs/actions/scroll/icon",
			"Tooltip": "Dial: scroll the frontmost window. Press: jump to top (or toggle speed). Tap: toggle fast/slow.",
			"PropertyInspectorPath": "ui/scroll-window.html",
			"Controllers": [
				"Encoder"
			],
			"Encoder": {
				"layout": "$B1",
				"TriggerDescription": {
					"Rotate": "Scroll up / down",
					"Push": "Jump to top (or toggle speed)",
					"Touch": "Toggle fast / slow"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/scroll/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Open / Switch App",
			"UUID": "com.movingavg.switchboard.switchapp",
			"Icon": "imgs/actions/switchapp/icon",
			"Tooltip": "Open or switch to an app, optionally focusing a window by title pattern. Hold to capture the frontmost app.",
			"PropertyInspectorPath": "ui/switch-app.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/switchapp/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Focus tmux Window",
			"UUID": "com.movingavg.switchboard.tmux",
			"Icon": "imgs/actions/tmux/icon",
			"Tooltip": "Raise the iTerm2 window for a tmux window, and optionally switch to it. Hold to capture the current tmux window.",
			"PropertyInspectorPath": "ui/focus-tmux.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/tmux/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Switch tmux Pane",
			"UUID": "com.movingavg.switchboard.tmuxpane",
			"Icon": "imgs/actions/tmuxpane/icon",
			"Tooltip": "Dial: rotate to switch tmux panes; push to exit copy-mode; tap to zoom/unzoom the pane.",
			"PropertyInspectorPath": "ui/tmux-pane.html",
			"Controllers": [
				"Encoder"
			],
			"Encoder": {
				"layout": "$B1",
				"TriggerDescription": {
					"Rotate": "Previous / next pane",
					"Push": "Exit copy-mode (scroll to bottom)",
					"Touch": "Zoom / unzoom pane"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/tmuxpane/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Cycle tmux Window",
			"UUID": "com.movingavg.switchboard.tmuxwindial",
			"Icon": "imgs/actions/tmuxwindial/icon",
			"Tooltip": "Dial: rotate to cycle tmux windows; push for last window; tap to widen the scope to all sessions.",
			"PropertyInspectorPath": "ui/tmux-window.html",
			"Controllers": [
				"Encoder"
			],
			"Encoder": {
				"layout": "layouts/tmux-window.json",
				"TriggerDescription": {
					"Rotate": "Previous / next window",
					"Push": "Last window / last session",
					"Touch": "Toggle scope: session / all"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/tmuxwindial/key",
					"TitleAlignment": "bottom"
				}
			],
			"UserTitleEnabled": false
		},
		{
			"Name": "Cycle App Windows",
			"UUID": "com.movingavg.switchboard.appwindows",
			"Icon": "imgs/actions/appwindows/icon",
			"Tooltip": "Dial: cycle the frontmost app's windows. Press or tap: toggle to cycling apps instead.",
			"PropertyInspectorPath": "ui/app-windows.html",
			"Controllers": [
				"Encoder"
			],
			"Encoder": {
				"layout": "layouts/app-windows.json",
				"TriggerDescription": {
					"Rotate": "Previous / next window (or app)",
					"Push": "Toggle windows / apps mode",
					"Touch": "Toggle windows / apps mode"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/appwindows/key",
					"TitleAlignment": "bottom"
				}
			],
			"UserTitleEnabled": false
		},
		{
			"Name": "BBEdit Documents",
			"UUID": "com.movingavg.switchboard.bbeditdoc",
			"Icon": "imgs/actions/bbeditdoc/icon",
			"Tooltip": "Dial: move between the open documents in BBEdit's front window. Press: back to the previous document.",
			"PropertyInspectorPath": "ui/bbedit-doc.html",
			"Controllers": [
				"Encoder"
			],
			"Encoder": {
				"layout": "$B1",
				"TriggerDescription": {
					"Rotate": "Previous / next document",
					"Push": "Back to previous document"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/bbeditdoc/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Open File",
			"UUID": "com.movingavg.switchboard.openfile",
			"Icon": "imgs/actions/openfile/icon",
			"Tooltip": "Open the newest / latest / pattern-matched file in a folder, with a live ✓/✗ status badge.",
			"PropertyInspectorPath": "ui/open-file.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/openfile/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Window Ring",
			"UUID": "com.movingavg.switchboard.windowring",
			"Icon": "imgs/actions/windowring/icon",
			"Tooltip": "Long-press to add/remove the current window; tap to cycle through your saved windows.",
			"PropertyInspectorPath": "ui/window-ring.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/windowring/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Arrange Window",
			"UUID": "com.movingavg.switchboard.tile",
			"Icon": "imgs/actions/tile/icon",
			"Tooltip": "Dial: rotate to tile the frontmost window through halves/thirds/quarters or a grid. Press to maximize.",
			"PropertyInspectorPath": "ui/arrange-window.html",
			"Controllers": [
				"Encoder"
			],
			"Encoder": {
				"layout": "$B1",
				"TriggerDescription": {
					"Rotate": "Tile clockwise / counter-clockwise",
					"Push": "Maximize"
				}
			},
			"States": [
				{
					"Image": "imgs/actions/tile/key",
					"TitleAlignment": "bottom"
				}
			]
		}
	]
}

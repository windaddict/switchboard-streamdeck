# Fastlane config for signing + notarizing Switchboard's native helpers
# (bin/macos/{scroll,tile,axcheck}). Mirrors the App Store Connect API key auth
# used by the Passages project — no Apple ID password or 2FA needed.
#
# One-time prerequisite: the same API key Passages uses, at
#   ~/.keys/AuthKey_RP35L4P23G.p8
# plus your match passphrase in MATCH_PASSWORD (as for Passages).
#
# Run:  bundle exec fastlane mac notarize_helpers

require "shellwords"

opt_out_usage

PLUGIN_DIR = "com.movingavg.switchboard.sdPlugin".freeze
HELPER_DIR = "#{PLUGIN_DIR}/bin/macos".freeze
# Bundle id used only to label the notarization submission.
NOTARY_BUNDLE_ID = "com.movingavg.switchboard.helpers".freeze

platform :mac do
  before_all do
    app_store_connect_api_key(
      key_id: "RP35L4P23G",
      issuer_id: "69a6de73-49f5-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.expand_path("~/.keys/AuthKey_RP35L4P23G.p8")
    )
  end

  desc "Build + sign the universal helpers and notarize them."
  desc "Prerequisite (one-time, Account Holder only — Apple forbids creating a"
  desc "Developer ID cert via API key): create a 'Developer ID Application'"
  desc "certificate in Xcode > Settings > Accounts > 9CHGJ6ZAE6 > Manage"
  desc "Certificates > + > Developer ID Application. Then `fastlane match import`"
  desc "it into the certs repo if you want it synced across machines."
  lane :notarize_helpers do
    root = File.expand_path("..", __dir__)
    helper_dir = File.join(root, HELPER_DIR)
    zip = File.join(root, "dist", "switchboard-helpers.zip")

    # 1. Pull the Developer ID cert from the match repo if it's there. readonly:
    #    never create it — Developer ID cert creation is Account-Holder /
    #    web-portal only and fails with an API key. If the repo has no such cert
    #    we fall back to whatever Developer ID cert is already in the keychain.
    begin
      match(
        type: "developer_id",
        app_identifier: [],
        skip_provisioning_profiles: true,
        readonly: true
      )
    rescue => e
      UI.important("match could not fetch a Developer ID cert from the repo (#{e.message}).")
      UI.important("Using a Developer ID cert from the local keychain instead, if present.")
    end

    # 2. Build the universal helpers; build:helper auto-signs them with the
    #    Developer ID cert in the keychain (hardened runtime + timestamp).
    sh("npm --prefix #{root.shellescape} run build:helper")

    # 3. Fail early with a precise fix if the helpers aren't Developer ID signed.
    %w[scroll tile axcheck].each do |name|
      info = sh("codesign -dvvv #{File.join(helper_dir, name).shellescape} 2>&1", log: false)
      next if info.include?("Authority=Developer ID Application")

      UI.user_error!(
        "#{name} is not Developer ID signed. Create a 'Developer ID Application' " \
        "certificate (Account Holder): Xcode > Settings > Accounts > 9CHGJ6ZAE6 > " \
        "Manage Certificates > + > Developer ID Application. Then re-run this lane."
      )
    end

    # 4. Zip the signed helpers and notarize. Bare CLI binaries can't be
    #    stapled, so Gatekeeper verifies them online on first run.
    sh("mkdir -p #{File.dirname(zip).shellescape} && ditto -c -k #{helper_dir.shellescape} #{zip.shellescape}")
    # notarytool is the only backend in this fastlane version (no use_notarytool flag).
    notarize(
      package: zip,
      bundle_id: NOTARY_BUNDLE_ID,
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY],
      skip_stapling: true,
      print_log: true
    )

    UI.success("Helpers signed + notarized. Run `npm run build && npm run pack` and cut the release.")
  end
end
